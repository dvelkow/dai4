#!/bin/bash

# Check if tmux is installed
if ! command -v tmux &> /dev/null
then
    echo "tmux is not installed. To install it, run: brew install tmux"
    exit 1
fi

SESSION_NAME="dai4-$$"

# Start a new detached tmux session
tmux new-session -d -s "$SESSION_NAME"

# Split the window into 4 panes
# tmux pane numbering shifts when you split. 
# 1. Split horizontally: Pane 0 (Left), Pane 1 (Right)
tmux split-window -h -t "$SESSION_NAME"

# 2. Split the Left pane vertically: Pane 0 (Top Left), Pane 1 (Bottom Left), Pane 2 (Right)
tmux split-window -v -t "$SESSION_NAME:0.0"

# 3. Split the Right pane vertically: Pane 0 (Top Left), Pane 1 (Bottom Left), Pane 2 (Top Right), Pane 3 (Bottom Right)
tmux split-window -v -t "$SESSION_NAME:0.2"

# Ensure they are equally sized
tmux select-layout -t "$SESSION_NAME" tiled

# ==========================================
#          DAI4 PRO FEATURES ENABLED
# ==========================================

# 1. Full Mouse Support
tmux set-option -t "$SESSION_NAME" mouse on

# 2. Massive Scrollback History
tmux set-option -t "$SESSION_NAME" history-limit 50000

# 3. Rich Colors
tmux set-option -t "$SESSION_NAME" default-terminal "screen-256color"

# 4. Active Pane Highlighting
tmux set-window-option -t "$SESSION_NAME" pane-active-border-style fg=green,bg=default
tmux set-window-option -t "$SESSION_NAME" pane-border-style fg=color240,bg=default

# 5. Snappy Key Responses
tmux set-option -t "$SESSION_NAME" escape-time 10

# ==========================================
#          CLIPBOARD & COPY/PASTE
# ==========================================

# Use vi-style keys in copy mode
tmux set-window-option -t "$SESSION_NAME" mode-keys vi

# Mouse drag selection auto-copies to system clipboard
tmux set-option -t "$SESSION_NAME" set-clipboard on
tmux bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"

# Right-click to paste from system clipboard
tmux bind-key -T root MouseDown3Pane run-shell "pbpaste | tmux load-buffer - && tmux paste-buffer"

# Ctrl+C in copy mode copies to system clipboard
tmux bind-key -T copy-mode-vi C-c send-keys -X copy-pipe-and-cancel "pbcopy"

# v to start selection, y to yank (copy) in copy mode
tmux bind-key -T copy-mode-vi v send-keys -X begin-selection
tmux bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"

# Double-click selects a word and copies it
tmux bind-key -T root DoubleClick1Pane select-pane \; copy-mode \; send-keys -X select-word \; send-keys -X copy-pipe-and-cancel "pbcopy"

# Middle-click pastes from system clipboard
tmux bind-key -T root MouseDown2Pane run-shell "pbpaste | tmux load-buffer - && tmux paste-buffer"

# ==========================================
#          EXTRA QOL FEATURES
# ==========================================

# Allow passthrough for images (sixel/kitty protocol)
tmux set-option -t "$SESSION_NAME" allow-passthrough on

# Enable focus events (helps editors detect focus)
tmux set-option -t "$SESSION_NAME" focus-events on

# Don't rename windows automatically
tmux set-option -t "$SESSION_NAME" allow-rename off

# Word separators for double-click word selection
tmux set-option -t "$SESSION_NAME" word-separators " -_@./"

# ==========================================
#          SLICKER STATUS BAR
# ==========================================

tmux set-option -t "$SESSION_NAME" status-position bottom
tmux set-option -t "$SESSION_NAME" status-style bg=color235,fg=white
# Left side: Cool badge
tmux set-option -t "$SESSION_NAME" status-left "#[bg=green,fg=black,bold] ◩ DAI4 PRO #[bg=default,fg=default] "
tmux set-option -t "$SESSION_NAME" status-left-length 30
# Right side: Date and Time
tmux set-option -t "$SESSION_NAME" status-right "#[fg=cyan]%b %d, %Y #[fg=color240]| #[fg=yellow,bold]%I:%M %p "

# ==========================================
#          AUTO-RUN AI COMMANDS
# ==========================================
# Pane 0 (Top Left): Run claude
tmux send-keys -t "$SESSION_NAME:0.0" "clear; claude" C-m

# Pane 1 (Bottom Left): Run gemini
tmux send-keys -t "$SESSION_NAME:0.1" "clear; gemini" C-m

# Pane 2 (Top Right): Run codex
tmux send-keys -t "$SESSION_NAME:0.2" "clear; codex" C-m

# Pane 3 (Bottom Right): Run omni
tmux send-keys -t "$SESSION_NAME:0.3" "clear; omni" C-m

# Attach to the session
tmux attach-session -t "$SESSION_NAME"